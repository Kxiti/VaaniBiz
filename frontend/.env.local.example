# VaaniBiz Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values

# Opportunities API Configuration
# This is the AWS API Gateway endpoint for the Opportunity Generator Lambda function
# Replace with your actual API Gateway URL before deployment
# Example: https://abc123xyz.execute-api.us-east-1.amazonaws.com/prod/opportunities
NEXT_PUBLIC_OPPORTUNITIES_API_URL=https://YOUR_API_GATEWAY_URL_HERE/opportunities
